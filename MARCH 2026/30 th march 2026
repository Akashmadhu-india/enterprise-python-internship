<!DOCTYPE html>
<html>
<head>
    <title>Nested Table</title>
</head>
<body>

<table border="1">
    <tr>
        <th>Table 1</th>
        <th>Table 2</th>
    </tr>

    <tr>
        <td>
            <table border="1">
                <tr>
                    <td>Row 1</td>
                    <td>Row 2</td>
                </tr>
            </table>
        </td>

        <td>
            <table border="1">
                <tr>
                    <td>Row A</td>
                    <td>Row B</td>
                </tr>
            </table>
        </td>
    </tr>

</table>

</body>
</html>
